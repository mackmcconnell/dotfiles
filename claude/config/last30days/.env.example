# last30days API Configuration
# All keys are optional - skill works with WebSearch fallback
# Copy to .env and fill in your keys: cp .env.example .env

# Reddit, TikTok, Instagram (one key covers all three)
SCRAPECREATORS_API_KEY=

# Reddit fallback (uses OpenAI's web_search tool)
OPENAI_API_KEY=

# X/Twitter research (uses xAI's x_search tool)
XAI_API_KEY=

# X/Twitter alternative: browser cookies (extract from x.com dev tools)
AUTH_TOKEN=
CT0=

# Bluesky (create app password at bsky.app/settings/app-passwords)
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# Truth Social (bearer token from browser dev tools)
TRUTHSOCIAL_TOKEN=

# Web search (pick one or more)
BRAVE_API_KEY=
PARALLEL_API_KEY=
OPENROUTER_API_KEY=
