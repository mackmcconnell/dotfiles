#!/bin/bash
# transcribe - Voice memo transcription pipeline
#
# What it does:
#   Records a voice memo on iPhone, then this command transcribes it into text
#   and sends it to a destination of your choice. Useful for brain dumps,
#   journaling, or capturing ideas while walking around.
#
# How it works:
#   1. Finds the latest .m4a/.qta file in the Voice Memos iCloud sync directory
#      (skips files already marked as transcribed)
#   2. Runs Whisper to convert speech to text (locally or via OpenAI API)
#   3. Sends the transcript to the chosen destination
#   4. Renames the original audio file with "(transcribed)" appended so you
#      know it's been processed and can delete it
#
# Usage:
#   transcribe [file|name|menu] [destination] [cloud]
#   transcribe --cloud "New Recording 80" daily
#   transcribe daily --cloud "New Recording 80"
#   transcribe --menu --cloud daily
#
# Destinations:
#   notes       Create a new Apple Note in the Transcriptions folder
#   daily       Append to today's Obsidian daily note (yyyy-mm-dd.md)
#   clipboard   Copy transcript to clipboard
#
# Environment:
#   WHISPER_MODEL           Whisper model size for local mode (default: "small")
#                           Options: tiny, base, small, medium, large
#   OPENAI_API_KEY          Required for --cloud mode
#
# Dependencies:
#   Local mode: openai-whisper (pip install openai-whisper)
#   Cloud mode: curl + OPENAI_API_KEY
#   Both: Voice Memos iCloud sync enabled on iPhone

set -euo pipefail

MODEL="${WHISPER_MODEL:-small}"
VOICE_MEMOS_DIR="$HOME/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings"
OBSIDIAN_DAILY_DIR="$HOME/My Drive/mack/daily"
USE_CLOUD=false
SHOW_MENU=false
DESTINATION=""
DEFAULT_DESTINATION="daily"

format_duration() {
    local total="${1:-0}"
    local minutes=$((total / 60))
    local seconds=$((total % 60))
    printf "%d:%02d" "$minutes" "$seconds"
}

# --- Parse arguments ---
AUDIO_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --cloud|cloud)
            USE_CLOUD=true
            ;;
        --menu|menu)
            SHOW_MENU=true
            ;;
        -h|--help|help)
            echo "Usage: transcribe [file|name|menu] [destination] [cloud]"
            echo ""
            echo "Destinations:"
            echo "  daily       Save to today's Obsidian daily note (default)"
            echo "  notes       Create a new Apple Note"
            echo "  clipboard   Copy to clipboard"
            echo ""
            echo "Examples:"
            echo "  transcribe --cloud \"New Recording 80\""
            echo "  transcribe cloud \"New Recording 80\""
            echo "  transcribe --cloud \"New Recording 80\" daily"
            echo "  transcribe daily cloud \"New Recording 80\""
            echo "  transcribe menu cloud daily"
            echo "  transcribe notes /path/to/audio.m4a"
            exit 0
            ;;
        notes|daily|clipboard)
            if [ -n "$DESTINATION" ]; then
                echo "Multiple destinations given: $DESTINATION and $arg"
                echo "Valid destinations: notes, daily, clipboard"
                exit 1
            fi
            DESTINATION="$arg"
            ;;
        *)
            AUDIO_ARGS+=("$arg")
            ;;
    esac
done
DESTINATION="${DESTINATION:-$DEFAULT_DESTINATION}"
set -- "${AUDIO_ARGS[@]+"${AUDIO_ARGS[@]}"}"

# --- Find audio file ---
if [ "$SHOW_MENU" = true ] && [ $# -eq 0 ]; then
    DB="$VOICE_MEMOS_DIR/CloudRecordings.db"
    if [ ! -f "$DB" ]; then
        echo "Voice Memos database not found."
        exit 1
    fi

    MENU_PATHS=()
    MENU_TITLES=()
    MENU_CREATED=()
    MENU_DURATIONS=()

    while IFS=$'\t' read -r path title created duration; do
        if [ -f "$VOICE_MEMOS_DIR/$path" ]; then
            MENU_PATHS+=("$path")
            MENU_TITLES+=("${title:-Untitled}")
            MENU_CREATED+=("$created")
            MENU_DURATIONS+=("$duration")
        fi
        if [ "${#MENU_PATHS[@]}" -ge 10 ]; then
            break
        fi
    done < <(sqlite3 -separator "$(printf '\t')" "$DB" "SELECT ZPATH, COALESCE(ZENCRYPTEDTITLE, 'Untitled'), datetime(ZDATE + 978307200, 'unixepoch', 'localtime'), COALESCE(CAST(ROUND(ZDURATION) AS INTEGER), 0) FROM ZCLOUDRECORDING WHERE ZPATH IS NOT NULL AND ZPATH != '' AND ZPATH NOT LIKE '%(transcribed)%' AND COALESCE(ZENCRYPTEDTITLE, '') NOT LIKE '%(transcribed)%' AND ZEVICTIONDATE IS NULL ORDER BY ZDATE DESC LIMIT 40;")

    if [ "${#MENU_PATHS[@]}" -eq 0 ]; then
        echo "No recent untranscribed voice memos found."
        exit 1
    fi

    echo "Recent Voice Memos:"
    for i in "${!MENU_PATHS[@]}"; do
        number=$((i + 1))
        duration_label=$(format_duration "${MENU_DURATIONS[$i]}")
        printf "  %2d) %s | %s | %s | %s\n" "$number" "${MENU_TITLES[$i]}" "${MENU_CREATED[$i]}" "$duration_label" "${MENU_PATHS[$i]}"
    done
    echo ""
    read -r -p "Choose recording number: " CHOICE

    if [[ ! "$CHOICE" =~ ^[0-9]+$ ]] || [ "$CHOICE" -lt 1 ] || [ "$CHOICE" -gt "${#MENU_PATHS[@]}" ]; then
        echo "Invalid choice: $CHOICE"
        exit 1
    fi

    AUDIO="$VOICE_MEMOS_DIR/${MENU_PATHS[$((CHOICE - 1))]}"
elif [ $# -gt 0 ] && [ -f "$1" ]; then
    AUDIO="$1"
elif [ $# -gt 0 ]; then
    # Look up by Voice Memos app name
    NAME="$*"
    DB="$VOICE_MEMOS_DIR/CloudRecordings.db"
    if [ ! -f "$DB" ]; then
        echo "Voice Memos database not found."
        exit 1
    fi
    ESCAPED_NAME=$(printf '%s' "$NAME" | sed "s/'/''/g")
    FILENAME=""
    while IFS= read -r candidate; do
        if [ -f "$VOICE_MEMOS_DIR/$candidate" ]; then
            FILENAME="$candidate"
            break
        fi
    done < <(sqlite3 "$DB" "SELECT ZPATH FROM ZCLOUDRECORDING WHERE ZENCRYPTEDTITLE = '$ESCAPED_NAME' AND ZPATH IS NOT NULL AND ZPATH != '' AND ZPATH NOT LIKE '%(transcribed)%' AND ZEVICTIONDATE IS NULL ORDER BY ZDATE DESC LIMIT 40;")
    if [ -z "$FILENAME" ]; then
        echo "No voice memo found with name: $NAME"
        exit 1
    fi
    AUDIO="$VOICE_MEMOS_DIR/$FILENAME"
    if [ ! -f "$AUDIO" ]; then
        echo "File not synced yet: $FILENAME"
        exit 1
    fi
else
    if [ ! -d "$VOICE_MEMOS_DIR" ]; then
        echo "Voice Memos not syncing to this Mac."
        echo "Enable in: iPhone Settings > Apple ID > iCloud > Voice Memos"
        echo ""
        echo "Or pass a file directly:"
        echo "  transcribe /path/to/audio.m4a"
        exit 1
    fi

    DB="$VOICE_MEMOS_DIR/CloudRecordings.db"
    AUDIO=""
    if [ -f "$DB" ]; then
        while IFS= read -r candidate; do
            if [ -f "$VOICE_MEMOS_DIR/$candidate" ]; then
                AUDIO="$VOICE_MEMOS_DIR/$candidate"
                break
            fi
        done < <(sqlite3 "$DB" "SELECT ZPATH FROM ZCLOUDRECORDING WHERE ZPATH IS NOT NULL AND ZPATH != '' AND ZPATH NOT LIKE '%(transcribed)%' AND COALESCE(ZENCRYPTEDTITLE, '') NOT LIKE '%(transcribed)%' AND ZEVICTIONDATE IS NULL ORDER BY ZDATE DESC LIMIT 40;")
    fi

    if [ -z "$AUDIO" ] && [ ! -f "$DB" ]; then
        AUDIO=$(find "$VOICE_MEMOS_DIR" \( -name "*.m4a" -o -name "*.qta" \) -not -name "*(transcribed)*" -type f | sort -r | head -1)
    fi

    if [ -z "${AUDIO:-}" ]; then
        echo "No untranscribed voice memos found."
        exit 1
    fi
fi

echo "Transcribing: $(basename "$AUDIO")"

# --- Transcribe ---
TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

if [ "$USE_CLOUD" = true ]; then
    # --- Cloud: OpenAI Whisper API ---
    if [ -z "${OPENAI_API_KEY:-}" ]; then
        echo "OPENAI_API_KEY not set. Required for --cloud mode."
        exit 1
    fi

    echo "Using OpenAI Whisper API..."

    # Convert .qta to .m4a if needed (API doesn't support .qta)
    UPLOAD_FILE="$AUDIO"
    if [[ "$AUDIO" == *.qta ]]; then
        UPLOAD_FILE="$TMP/$(basename "${AUDIO%.*}").m4a"
        ffmpeg -i "$AUDIO" -codec copy "$UPLOAD_FILE" -y -loglevel error
    fi

    RESPONSE=$(curl -s -X POST "https://api.openai.com/v1/audio/transcriptions" \
        -H "Authorization: Bearer $OPENAI_API_KEY" \
        -F "file=@$UPLOAD_FILE" \
        -F "model=whisper-1" \
        -F "language=en" \
        -F "response_format=text" \
        -F "prompt=Hello, welcome. This is a recording with proper punctuation, including commas, periods, and question marks.")

    if [ -z "$RESPONSE" ] || echo "$RESPONSE" | grep -q '"error"'; then
        echo "Transcription failed: $RESPONSE"
        exit 1
    fi

    TRANSCRIPT="$RESPONSE"
else
    # --- Local: openai-whisper ---
    if ! command -v whisper &>/dev/null; then
        echo ""
        echo "whisper not installed. Run:"
        echo "  pip install openai-whisper"
        echo ""
        echo "Or use --cloud for the OpenAI API instead."
        exit 1
    fi

    echo "Using local Whisper ($MODEL model)..."
    whisper "$AUDIO" --model "$MODEL" --language en --output_format txt --output_dir "$TMP" 2>/dev/null

    TRANSCRIPT_FILE="$TMP/$(basename "${AUDIO%.*}").txt"

    if [ ! -f "$TRANSCRIPT_FILE" ] || [ ! -s "$TRANSCRIPT_FILE" ]; then
        echo "Transcription failed or came back empty."
        exit 1
    fi

    TRANSCRIPT=$(cat "$TRANSCRIPT_FILE")
fi

# --- Send to destination ---
case "$DESTINATION" in
    notes)
        NOTE_TITLE="Brain Dump - $(date '+%B %d, %Y %-I:%M %p')"
        BODY_FILE=$(mktemp)
        printf '%s' "$TRANSCRIPT" > "$BODY_FILE"

        osascript - "$NOTE_TITLE" "$BODY_FILE" <<'APPLESCRIPT'
on run argv
    set noteTitle to item 1 of argv
    set bodyPath to item 2 of argv
    set noteBody to do shell script "cat " & quoted form of bodyPath
    tell application "Notes"
        make new note at folder "Transcriptions" with properties {name:noteTitle, body:noteBody}
    end tell
end run
APPLESCRIPT

        rm -f "$BODY_FILE"
        echo "Created Apple Note: $NOTE_TITLE"
        ;;

    daily)
        TODAY=$(date '+%Y-%m-%d')
        DAILY_FILE="$OBSIDIAN_DAILY_DIR/$TODAY.md"

        if [ -f "$DAILY_FILE" ]; then
            printf '\n\n---\n\n%s' "$TRANSCRIPT" >> "$DAILY_FILE"
        else
            printf '%s' "$TRANSCRIPT" > "$DAILY_FILE"
        fi

        echo "Saved to daily note: $DAILY_FILE"
        ;;

    clipboard)
        printf '%s' "$TRANSCRIPT" | pbcopy
        echo "Transcript copied to clipboard."
        ;;
esac

# --- Mark audio as transcribed ---
DIR=$(dirname "$AUDIO")
EXT="${AUDIO##*.}"
BASE=$(basename "$AUDIO" ".$EXT")
mv "$AUDIO" "$DIR/${BASE} (transcribed).$EXT"

# Update title in Voice Memos app database
DB="$VOICE_MEMOS_DIR/CloudRecordings.db"
FILENAME=$(basename "$AUDIO")
if [ -f "$DB" ]; then
    CURRENT_TITLE=$(sqlite3 "$DB" "SELECT ZENCRYPTEDTITLE FROM ZCLOUDRECORDING WHERE ZPATH = '$FILENAME';")
    if [ -n "$CURRENT_TITLE" ]; then
        sqlite3 "$DB" "UPDATE ZCLOUDRECORDING SET ZENCRYPTEDTITLE = '${CURRENT_TITLE} (transcribed)' WHERE ZPATH = '$FILENAME';"
    else
        sqlite3 "$DB" "UPDATE ZCLOUDRECORDING SET ZENCRYPTEDTITLE = '(transcribed)' WHERE ZPATH = '$FILENAME';"
    fi
fi

echo "Renamed: $(basename "$AUDIO") -> ${BASE} (transcribed).$EXT"
echo "---"
echo "$TRANSCRIPT"
